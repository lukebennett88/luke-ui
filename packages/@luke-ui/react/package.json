{
	"name": "@luke-ui/react",
	"version": "0.0.0",
	"license": "MIT",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": [
		"**/*.css.ts",
		"./dist/stylesheet.css",
		"./dist/themes/*.css"
	],
	"exports": {
		"./box": "./dist/box/index.js",
		"./button": "./dist/button/index.js",
		"./button/primitive": "./dist/button/primitive/index.js",
		"./combobox-field": "./dist/combobox-field/index.js",
		"./combobox-field/primitive": "./dist/combobox-field/primitive/index.js",
		"./emoji": "./dist/emoji/index.js",
		"./field/primitive": "./dist/field/primitive/index.js",
		"./heading": "./dist/heading/index.js",
		"./heading-context": "./dist/heading-context/index.js",
		"./icon": "./dist/icon/index.js",
		"./icon-button": "./dist/icon-button/index.js",
		"./icon-size-context": "./dist/icon-size-context/index.js",
		"./link": "./dist/link/index.js",
		"./loading-skeleton": "./dist/loading-skeleton/index.js",
		"./loading-spinner": "./dist/loading-spinner/index.js",
		"./numeral": "./dist/numeral/index.js",
		"./recipes": "./dist/recipes/index.js",
		"./styles": "./dist/styles/index.js",
		"./text": "./dist/text/index.js",
		"./text-field": "./dist/text-field/index.js",
		"./text-field/primitive": "./dist/text-field/primitive/index.js",
		"./theme": "./dist/theme/index.js",
		"./themes": "./dist/themes/index.js",
		"./utils": "./dist/utils/index.js",
		"./package.json": "./package.json",
		"./stylesheet.css": "./dist/stylesheet.css",
		"./spritesheet.svg": "./dist/spritesheet.svg",
		"./themes/tactile.css": "./dist/themes/tactile.css",
		"./themes/paper.css": "./dist/themes/paper.css"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "pnpm run build:tsdown",
		"build:storybook": "storybook build",
		"build:tsdown": "vp pack",
		"check:barrels": "unbarrelify --check --skip src/styles/index.ts --skip src/combobox-field/primitive/index.tsx",
		"check:format": "vp fmt . --check",
		"check:lint": "vp lint . --type-aware",
		"check:types": "pnpm run check:types:storybook && pnpm run check:types:browser && pnpm run check:types:node",
		"check:types:browser": "tsc --noEmit -p tsconfig.json",
		"check:types:node": "tsc --noEmit -p scripts/tsconfig.json",
		"check:types:storybook": "tsc --noEmit -p tsconfig.storybook.json",
		"clean": "rm -rf .turbo .generated dist storybook-static",
		"dev": "pnpm run dev:tsdown",
		"dev:storybook": "rm -rf node_modules/.cache/storybook node_modules/.vite-storybook && storybook dev -p 6006",
		"dev:tsdown": "vp pack --watch",
		"fix:format": "vp fmt . --write",
		"fix:lint": "vp lint . --type-aware --fix",
		"fix:unsafe": "vp lint . --type-aware --fix-dangerously",
		"generate": "pnpm run generate:assets",
		"generate:assets": "pnpm run generate:icons && pnpm run generate:themes",
		"generate:icons": "tsx scripts/build-icons.ts",
		"generate:themes": "tsx scripts/build-themes.ts",
		"test": "pnpm run test:unit && pnpm run test:browser && pnpm run test:storybook && pnpm run test:visual",
		"test:browser": "vp test run --project=browser",
		"test:storybook": "vp test run --project=storybook",
		"test:ui": "vp test --project=storybook --ui",
		"test:unit": "vp test run --project=unit",
		"test:visual": "tsx scripts/visual-regression.ts",
		"test:visual:capture": "vp test run --project=visual --update",
		"test:visual:report": "tsx scripts/open-visual-report.ts",
		"test:watch": "vp test --project=storybook"
	},
	"dependencies": {
		"@capsizecss/metrics": "catalog:",
		"@capsizecss/vanilla-extract": "catalog:",
		"@luke-ui/rainbow-sprinkles": "workspace:*",
		"@react-aria/utils": "catalog:",
		"@vanilla-extract/css": "catalog:",
		"@vanilla-extract/recipes": "catalog:",
		"react-aria-components": "catalog:"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "catalog:",
		"@rollup/plugin-babel": "catalog:",
		"@storybook/addon-a11y": "catalog:",
		"@storybook/addon-docs": "catalog:",
		"@storybook/addon-vitest": "catalog:",
		"@storybook/react-vite": "catalog:",
		"@types/node": "catalog:",
		"@types/pngjs": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vanilla-extract/rollup-plugin": "catalog:",
		"@vanilla-extract/vite-plugin": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"@vitest/ui": "catalog:",
		"babel-plugin-react-compiler": "catalog:",
		"node-html-parser": "catalog:",
		"pixelmatch": "catalog:",
		"playwright": "catalog:",
		"pngjs": "catalog:",
		"postcss": "catalog:",
		"postcss-selector-parser": "catalog:",
		"publint": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"storybook": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"unbarrelify": "catalog:",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:"
	}
}
