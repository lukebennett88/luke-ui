{
	"name": "@luke-ui/react",
	"version": "0.0.0",
	"license": "MIT",
	"type": "module",
	"sideEffects": [
		"**/*.css.ts",
		"./dist/stylesheet.css"
	],
	"exports": {
		"./button": "./dist/button/index.js",
		"./button/primitive": "./dist/button/primitive.js",
		"./close-button": "./dist/close-button/index.js",
		"./combobox": "./dist/combobox/index.js",
		"./combobox-field": "./dist/combobox-field/index.js",
		"./emoji": "./dist/emoji/index.js",
		"./field": "./dist/field/index.js",
		"./field/primitive": "./dist/field/primitive.js",
		"./heading": "./dist/heading/index.js",
		"./heading-context": "./dist/heading-context/index.js",
		"./icon": "./dist/icon/index.js",
		"./icon-button": "./dist/icon-button/index.js",
		"./icon-size-context": "./dist/icon-size-context/index.js",
		"./link": "./dist/link/index.js",
		"./loading-spinner": "./dist/loading-spinner/index.js",
		"./numeral": "./dist/numeral/index.js",
		"./recipes": "./dist/recipes/index.js",
		"./text": "./dist/text/index.js",
		"./text-field": "./dist/text-field/index.js",
		"./text-input": "./dist/text-input/index.js",
		"./theme": "./dist/theme/index.js",
		"./tokens": "./dist/tokens/index.js",
		"./utils": "./dist/utils/index.js",
		"./package.json": "./package.json",
		"./stylesheet.css": "./dist/stylesheet.css",
		"./spritesheet.svg": "./dist/spritesheet.svg"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "pnpm run build:tsdown",
		"build:storybook": "storybook build",
		"build:tsdown": "tsdown --config-loader unrun",
		"check:format": "pnpm exec oxfmt -c ../../../.oxfmtrc.json --check .",
		"check:lint": "pnpm exec oxlint . --type-aware",
		"check:types": "pnpm run check:types:storybook && pnpm run check:types:browser && pnpm run check:types:node",
		"check:types:browser": "tsc --noEmit -p tsconfig.json",
		"check:types:node": "tsc --noEmit -p scripts/tsconfig.json",
		"check:types:storybook": "tsc --noEmit -p tsconfig.storybook.json",
		"clean": "rm -rf .turbo .generated dist storybook-static",
		"dev": "pnpm run dev:tsdown",
		"dev:storybook": "rm -rf node_modules/.cache/storybook node_modules/.vite-storybook && storybook dev -p 6006",
		"dev:tsdown": "tsdown --watch --config-loader unrun",
		"fix:format": "pnpm exec oxfmt -c ../../../.oxfmtrc.json .",
		"fix:lint": "pnpm exec oxlint . --type-aware --fix",
		"fix:unsafe": "pnpm exec oxlint . --type-aware --fix-dangerously",
		"generate": "pnpm run generate:icons && pnpm run generate:color-tokens",
		"generate:color-tokens": "node scripts/generate-color-tokens.ts && pnpm exec oxfmt -c ../../../.oxfmtrc.json .generated/color-tokens.generated.ts",
		"generate:icons": "tsx scripts/build-icons.ts",
		"test": "tsx scripts/test-visual.ts",
		"test:ui": "vitest --project=storybook --ui",
		"test:watch": "vitest --project=storybook"
	},
	"dependencies": {
		"@capsizecss/metrics": "^3.7.0",
		"@capsizecss/vanilla-extract": "^2.0.4",
		"@react-aria/utils": "^3.34.0",
		"@vanilla-extract/css": "^1.20.1",
		"@vanilla-extract/recipes": "^0.5.7",
		"react-aria-components": "^1.17.0"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@argos-ci/storybook": "catalog:",
		"@rollup/plugin-babel": "^7.0.0",
		"@storybook/addon-a11y": "catalog:",
		"@storybook/addon-docs": "catalog:",
		"@storybook/addon-vitest": "catalog:",
		"@storybook/react-vite": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vanilla-extract/rollup-plugin": "^1.5.3",
		"@vanilla-extract/vite-plugin": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"@vitest/ui": "catalog:",
		"babel-plugin-react-compiler": "^1.0.0",
		"colorjs.io": "^0.6.1",
		"node-html-parser": "^7.1.0",
		"playwright": "^1.59.1",
		"publint": "^0.3.18",
		"react": "catalog:",
		"react-dom": "catalog:",
		"storybook": "catalog:",
		"tsdown": "^0.21.10",
		"tsx": "catalog:",
		"typescript": "^6.0.3",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:"
	}
}
