{
	"$schema": "https://v2-8-10.turborepo.dev/schema.json",
	"tasks": {
		"@luke-ui/react#check:lint": {
			"dependsOn": ["build", "generate"]
		},
		"@luke-ui/react#check:docs": {
			"dependsOn": ["build"]
		},
		"@luke-ui/react#check:types": {
			"dependsOn": ["build", "^build"]
		},
		"@luke-ui/react#generate:docs": {
			"dependsOn": ["build"],
			"outputs": ["docs/**", "dist/docs/**"]
		},
		"//#check:format-root": {
			"cache": true
		},
		"//#check:unused": {
			"cache": true,
			"dependsOn": ["@luke-ui/react#generate", "docs#generate"]
		},
		"//#fix:format-root": {
			"cache": false
		},
		"//#fix:unused": {
			"cache": false,
			"dependsOn": ["@luke-ui/react#generate", "docs#generate"]
		},
		"build": {
			"dependsOn": ["^build", "generate"],
			"env": ["VITE_BASE_URL"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".output/**", ".source/**"]
		},
		"build:storybook": {
			"dependsOn": ["build", "generate"],
			"env": ["STORYBOOK_BASE_PATH"],
			"outputs": ["storybook-static/**"]
		},
		"check": {
			"dependsOn": ["check:format", "check:lint", "check:types", "check:docs"]
		},
		"check:docs": {
			"dependsOn": ["^generate"]
		},
		"check:format": {
			"dependsOn": ["generate"]
		},
		"check:lint": {
			"dependsOn": ["generate", "^build"]
		},
		"check:types": {
			"dependsOn": ["generate", "^build"]
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"dependsOn": ["generate", "^build"],
			"persistent": true
		},
		"docs#build": {
			"dependsOn": ["generate", "^build", "@luke-ui/react#generate:docs"],
			"env": ["VITE_BASE_URL"],
			"outputs": [".output/**", ".source/**"]
		},
		"docs#dev": {
			"cache": false,
			"dependsOn": ["generate", "^build", "@luke-ui/react#generate:docs"],
			"persistent": true
		},
		"dev:storybook": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		},
		"fix": {
			"cache": false,
			"dependsOn": ["fix:format", "fix:lint"]
		},
		"fix:format": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"fix:lint": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"fix:unsafe": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"generate": {
			"dependsOn": ["^generate"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!docs/**",
				"!dist/**",
				"!.generated/**",
				"!storybook-static/**",
				"!**/*.test.ts",
				"!**/*.test.tsx",
				"!**/*.stories.tsx"
			],
			"outputs": [
				".generated/**",
				"dist/spritesheet.svg",
				"dist/docs/**",
				"src/routeTree.gen.ts",
				"docs/**"
			]
		},
		"test": {
			"dependsOn": ["^build", "generate"],
			"outputs": []
		},
		"test:ui": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		},
		"test:watch": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		}
	}
}
