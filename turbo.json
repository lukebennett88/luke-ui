{
	"$schema": "https://v2-8-10.turborepo.dev/schema.json",
	"tasks": {
		"@luke-ui/react#check:lint": {
			"dependsOn": ["build", "generate"]
		},
		"@luke-ui/react#check:types": {
			"dependsOn": ["build", "^build"]
		},
		"@luke-ui/react#fix:lint": {
			"dependsOn": ["build", "generate"]
		},
		"//#check:format-root": {
			"cache": true
		},
		"//#check:unused": {
			"cache": true,
			"dependsOn": ["@luke-ui/react#generate", "docs#generate"]
		},
		"//#fix:format-root": {
			"cache": false
		},
		"//#fix:unused": {
			"cache": false,
			"dependsOn": ["@luke-ui/react#generate", "docs#generate"]
		},
		"build": {
			"dependsOn": ["^build", "generate"],
			"env": ["VITE_BASE_URL"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".output/**", ".source/**"]
		},
		"build:storybook": {
			"dependsOn": ["build", "generate"],
			"env": ["STORYBOOK_BASE_PATH"],
			"outputs": ["storybook-static/**"]
		},
		"check": {
			"dependsOn": ["check:format", "check:lint", "check:types"]
		},
		"check:format": {
			"dependsOn": ["generate"]
		},
		"check:lint": {
			"dependsOn": ["generate", "^build"]
		},
		"check:types": {
			"dependsOn": ["generate", "^build"]
		},
		"clean": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"dependsOn": ["generate", "^build"],
			"persistent": true
		},
		"dev:storybook": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		},
		"docs#build": {
			"dependsOn": ["docs#generate", "^build"],
			"env": ["VITE_BASE_URL"],
			"outputs": [".netlify/**", ".output/**", ".source/**", "dist/**"]
		},
		"docs#check:format": {
			"dependsOn": ["docs#generate"]
		},
		"docs#check:lint": {
			"dependsOn": ["docs#generate", "^build"]
		},
		"docs#check:types": {
			"dependsOn": ["docs#generate", "^build"]
		},
		"docs#dev": {
			"cache": false,
			"dependsOn": ["docs#generate", "^build"],
			"persistent": true
		},
		"docs#generate": {
			"cache": true,
			"dependsOn": ["^build"],
			"outputs": ["src/routeTree.gen.ts", "src/generated/**"]
		},
		"fix": {
			"cache": false,
			"dependsOn": ["fix:format", "fix:lint"]
		},
		"fix:format": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"fix:lint": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"fix:unsafe": {
			"cache": false,
			"dependsOn": ["generate"]
		},
		"generate": {
			"dependsOn": ["^generate"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.generated/**",
				"!storybook-static/**",
				"!styled-system/**",
				"!src/theme/token-map.json",
				"!**/*.test.ts",
				"!**/*.test.tsx",
				"!**/*.stories.tsx"
			],
			"outputs": [
				".generated/**",
				"dist/spritesheet.svg",
				"dist/themes/**",
				"src/routeTree.gen.ts",
				"src/theme/token-map.json",
				"styled-system/**"
			]
		},
		"test": {
			"dependsOn": ["^build", "generate"],
			"outputs": []
		},
		"test:ui": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		},
		"test:watch": {
			"cache": false,
			"dependsOn": ["generate"],
			"persistent": true
		}
	}
}
